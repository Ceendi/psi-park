# ---- Django ----
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.dev

# ---- Database (PostgreSQL) ----
POSTGRES_DB=psipark
POSTGRES_USER=psipark
POSTGRES_PASSWORD=psipark
DATABASE_URL=postgres://psipark:psipark@db:5432/psipark

# ---- Redis (Channels) ----
REDIS_URL=redis://redis:6379/0

# ---- CORS / frontend ----
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# ---- E-mail (Mailpit) ----
EMAIL_HOST=mailpit
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@psipark.local

# ---- Stripe (test mode) ----
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Business rules ----
PLATFORM_FEE_PERCENT=10
RESERVATION_PAYMENT_TTL_MINUTES=30
FREE_CANCELLATION_HOURS=24

# ---- Seed admin ----
DJANGO_SUPERUSER_EMAIL=admin@psipark.local
DJANGO_SUPERUSER_PASSWORD=admin12345
